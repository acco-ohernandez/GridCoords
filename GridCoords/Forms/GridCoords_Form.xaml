<Window x:Class="GridCoords.Forms.GridCoords_Form"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Grid Coords"
        Height="700" Width="820"
        MinHeight="450" MinWidth="600"
        ResizeMode="CanResize"
        Topmost="True"
        WindowStartupLocation="Manual">

    <Window.Resources>
        <Style TargetType="Expander">
            <Setter Property="Margin"          Value="0,0,0,6"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="IsExpanded"      Value="True"/>
            <Setter Property="BorderBrush"     Value="#CCCCCC"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>
        <Style TargetType="RadioButton">
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Margin"     Value="0,2,12,2"/>
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="FontWeight" Value="Normal"/>
            <Setter Property="Margin"     Value="0,2,0,2"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Padding"  Value="8,3"/>
            <Setter Property="MinWidth" Value="60"/>
        </Style>
        <Style x:Key="NumericInput" TargetType="TextBox">
            <Setter Property="Width"                      Value="60"/>
            <Setter Property="Height"                     Value="22"/>
            <Setter Property="VerticalContentAlignment"   Value="Center"/>
            <Setter Property="FontWeight"                 Value="Normal"/>
            <Setter Property="Margin"                     Value="4,0,4,0"/>
        </Style>
    </Window.Resources>

    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ═══ Two-column main content ═══════════════════════════ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"    MinWidth="260"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="1.2*" MinWidth="300"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ LEFT COLUMN: Settings ═════════════════════════ -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- ── PLACEMENT MODE ─────────────────────── -->
                    <Expander Header="Placement Mode">
                        <StackPanel Margin="2,4">
                            <RadioButton x:Name="RbTextNote"
                                         Content="TextNote"
                                         GroupName="PlacementMode"
                                         IsChecked="True"
                                         Checked="PlacementMode_Changed"/>
                            <RadioButton x:Name="RbFamilyInstance"
                                         Content="Family Instance (Generic Annotation)"
                                         GroupName="PlacementMode"
                                         Checked="PlacementMode_Changed"/>

                            <!-- TextNote options -->
                            <StackPanel x:Name="PnlTextNoteOptions" Margin="0,6,0,0">
                                <DockPanel>
                                    <TextBlock Text="Text Type:"
                                               Width="70"
                                               VerticalAlignment="Center"
                                               FontWeight="Normal"/>
                                    <ComboBox x:Name="CmbTextNoteTypes"
                                              DisplayMemberPath="Name"
                                              FontWeight="Normal"/>
                                </DockPanel>
                            </StackPanel>

                            <!-- FamilyInstance options -->
                            <StackPanel x:Name="PnlFamilyOptions"
                                        Margin="0,6,0,0"
                                        Visibility="Collapsed">
                                <DockPanel>
                                    <TextBlock Text="Family:"
                                               Width="70"
                                               VerticalAlignment="Center"
                                               FontWeight="Normal"/>
                                    <ComboBox x:Name="CmbFamilyTypes"
                                              DisplayMemberPath="Name"
                                              FontWeight="Normal"
                                              SelectionChanged="CmbFamilyTypes_SelectionChanged"/>
                                </DockPanel>
                                <DockPanel Margin="0,4,0,0">
                                    <TextBlock Text="Parameter:"
                                               Width="70"
                                               VerticalAlignment="Center"
                                               FontWeight="Normal"/>
                                    <ComboBox x:Name="CmbParameters"
                                              DisplayMemberPath="Name"
                                              FontWeight="Normal"/>
                                </DockPanel>
                            </StackPanel>
                        </StackPanel>
                    </Expander>

                    <!-- ── LABEL FORMAT ───────────────────────── -->
                    <Expander Header="Label Format">
                        <StackPanel Margin="2,4">
                            <DockPanel>
                                <TextBlock Text="Template:"
                                           Width="70"
                                           VerticalAlignment="Center"
                                           FontWeight="Normal"
                                           ToolTip="Define the label format using tokens:&#x0a;&#x0a;  {H} = Horizontal grid name&#x0a;  {V} = Vertical grid name&#x0a;&#x0a;Examples:&#x0a;  ({H},{V})      →  (A,3)&#x0a;  {H}-{V}        →  A-3&#x0a;  {H}/{V}        →  A/3&#x0a;  Grid {H}.{V}   →  Grid A.3&#x0a;  [{V},{H}]      →  [3,A]&#x0a;&#x0a;Use the Order setting below to swap&#x0a;which grid name fills {H} vs {V}."/>
                                <TextBox x:Name="TxtLabelTemplate"
                                         Text="({H},{V})"
                                         FontWeight="Normal"
                                         TextChanged="TxtLabelTemplate_TextChanged"/>
                            </DockPanel>

                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="Order:"
                                           Width="70"
                                           VerticalAlignment="Center"
                                           FontWeight="Normal"/>
                                <RadioButton x:Name="RbOrderHV"
                                             Content="(H, V)"
                                             GroupName="NameOrder"
                                             IsChecked="True"
                                             Checked="NameOrder_Changed"/>
                                <RadioButton x:Name="RbOrderVH"
                                             Content="(V, H)"
                                             GroupName="NameOrder"
                                             Checked="NameOrder_Changed"/>
                            </StackPanel>

                            <DockPanel Margin="0,6,0,0">
                                <TextBlock Text="Preview:"
                                           Width="70"
                                           VerticalAlignment="Center"
                                           FontWeight="Normal"/>
                                <TextBlock x:Name="TblFormatPreview"
                                           Text="(A,1)"
                                           FontWeight="Normal"
                                           FontStyle="Italic"
                                           Foreground="Gray"
                                           VerticalAlignment="Center"/>
                            </DockPanel>
                        </StackPanel>
                    </Expander>

                    <!-- ── PLACEMENT OPTIONS ──────────────────── -->
                    <Expander Header="Placement Options">
                        <StackPanel Margin="2,4">
                            <DockPanel>
                                <CheckBox x:Name="CkOffsetAuto"
                                          Content="Auto"
                                          IsChecked="True"
                                          DockPanel.Dock="Right"
                                          Checked="OffsetAuto_Changed"
                                          Unchecked="OffsetAuto_Changed"
                                          ToolTip="Automatically scale offset based on view scale."/>
                                <TextBlock Text="Offset mode:"
                                           VerticalAlignment="Center"
                                           FontWeight="Normal"
                                           Width="80"/>
                            </DockPanel>

                            <DockPanel Margin="0,4,0,0">
                                <TextBlock Text="Offset X:"
                                           VerticalAlignment="Center"
                                           FontWeight="Normal"
                                           Width="80"/>
                                <TextBox x:Name="TxtOffsetX"
                                         Style="{StaticResource NumericInput}"
                                         Text="0.125"
                                         IsEnabled="False"/>
                                <TextBlock Text="in (paper)"
                                           VerticalAlignment="Center"
                                           FontWeight="Normal"
                                           Margin="2,0,0,0"/>
                            </DockPanel>

                            <DockPanel Margin="0,4,0,0">
                                <TextBlock Text="Offset Y:"
                                           VerticalAlignment="Center"
                                           FontWeight="Normal"
                                           Width="80"/>
                                <TextBox x:Name="TxtOffsetY"
                                         Style="{StaticResource NumericInput}"
                                         Text="0.125"
                                         IsEnabled="False"/>
                                <TextBlock Text="in (paper)"
                                           VerticalAlignment="Center"
                                           FontWeight="Normal"
                                           Margin="2,0,0,0"/>
                            </DockPanel>
                        </StackPanel>
                    </Expander>

                    <!-- ── EXISTING LABELS ────────────────────── -->
                    <Expander Header="Existing Labels">
                        <StackPanel Margin="2,4">
                            <RadioButton x:Name="RbDeleteExisting"
                                         Content="Delete existing labels first"
                                         GroupName="ExistingLabels"
                                         IsChecked="True"
                                         ToolTip="Remove all labels placed by this tool before placing new ones."/>
                            <RadioButton x:Name="RbSkipExisting"
                                         Content="Skip intersections with existing labels"
                                         GroupName="ExistingLabels"
                                         ToolTip="Leave existing labels in place and only add missing ones."/>
                            <RadioButton x:Name="RbDuplicates"
                                         Content="Place duplicates anyway"
                                         GroupName="ExistingLabels"
                                         ToolTip="Place labels at all intersections regardless of existing ones."/>
                        </StackPanel>
                    </Expander>

                </StackPanel>
            </ScrollViewer>

            <!-- ═══ RIGHT COLUMN: Grids + Results ═════════════════ -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- ── VIEW INFO + REFRESH ────────────────────── -->
                <DockPanel Grid.Row="0" Margin="0,0,0,6">
                    <Button x:Name="BtnRefreshGrids"
                            Content="Refresh"
                            DockPanel.Dock="Right"
                            Click="BtnRefreshGrids_Click"
                            ToolTip="Refresh grid list from the active view"/>
                    <TextBlock x:Name="TblViewName"
                               Text="View: —"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               FontStyle="Italic"
                               Foreground="Gray"/>
                </DockPanel>

                <!-- ── GRID SCOPE ─────────────────────────────── -->
                <Expander Grid.Row="1" Header="Grid Scope">
                    <StackPanel Margin="2,4">
                        <RadioButton x:Name="RbScopeAllVisible"
                                     Content="All Visible Grids"
                                     GroupName="GridScope"
                                     IsChecked="True"
                                     Checked="GridScope_Changed"/>
                        <RadioButton x:Name="RbScopeSelected"
                                     Content="Currently Selected Grids"
                                     GroupName="GridScope"
                                     Checked="GridScope_Changed"
                                     ToolTip="Uses grids currently selected in Revit. Auto-refreshes when selection changes."/>
                        <DockPanel Margin="0,2,0,0">
                            <RadioButton x:Name="RbScopePick"
                                         Content="Pick Grids"
                                         GroupName="GridScope"
                                         DockPanel.Dock="Left"
                                         Checked="GridScope_Changed"/>
                            <StackPanel Orientation="Horizontal"
                                        DockPanel.Dock="Right"
                                        HorizontalAlignment="Right">
                                <Button x:Name="BtnPick"
                                        Content="Pick"
                                        IsEnabled="False"
                                        Click="BtnPick_Click"
                                        ToolTip="Click grids in the Revit canvas to select them"/>
                                <Button x:Name="BtnClearPick"
                                        Content="Clear"
                                        IsEnabled="False"
                                        Click="BtnClearPick_Click"
                                        Margin="4,0,0,0"/>
                                <TextBlock x:Name="TblPickCount"
                                           Visibility="Collapsed"
                                           VerticalAlignment="Center"
                                           Foreground="Gray"
                                           FontStyle="Italic"
                                           FontWeight="Normal"
                                           Margin="6,0,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </StackPanel>
                </Expander>

                <!-- ── HORIZONTAL GRIDS ───────────────────────── -->
                <Expander Grid.Row="2" x:Name="ExpanderHGrids" Header="Horizontal Grids">
                    <DockPanel Margin="2,4">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                            <CheckBox x:Name="CkSelectAllH"
                                      Content="Select All"
                                      IsChecked="True"
                                      Checked="CkSelectAllH_Changed"
                                      Unchecked="CkSelectAllH_Changed"/>
                        </DockPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="HGridList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding GridName}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Margin="0,2,12,2"
                                                  FontWeight="Normal"
                                                  Checked="GridCheckBox_Changed"
                                                  Unchecked="GridCheckBox_Changed"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Expander>

                <!-- ── VERTICAL GRIDS ─────────────────────────── -->
                <Expander Grid.Row="3" x:Name="ExpanderVGrids" Header="Vertical Grids">
                    <DockPanel Margin="2,4">
                        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,4">
                            <CheckBox x:Name="CkSelectAllV"
                                      Content="Select All"
                                      IsChecked="True"
                                      Checked="CkSelectAllV_Changed"
                                      Unchecked="CkSelectAllV_Changed"/>
                        </DockPanel>
                        <ScrollViewer VerticalScrollBarVisibility="Auto">
                            <ItemsControl x:Name="VGridList">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding GridName}"
                                                  IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                                  Margin="0,2,12,2"
                                                  FontWeight="Normal"
                                                  Checked="GridCheckBox_Changed"
                                                  Unchecked="GridCheckBox_Changed"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DockPanel>
                </Expander>

                <!-- ── ANGLED / CURVED GRIDS ──────────────────── -->
                <Expander Grid.Row="4" x:Name="ExpanderOtherGrids"
                          Header="Angled / Curved (excluded)"
                          IsExpanded="False"
                          Visibility="Collapsed">
                    <StackPanel Margin="2,4">
                        <TextBlock Text="Reassign these grids to Horizontal or Vertical:"
                                   FontWeight="Normal" FontStyle="Italic" Foreground="Gray"
                                   Margin="0,0,0,4"/>
                        <ItemsControl x:Name="OtherGridList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="0,2,0,2">
                                        <TextBlock Text="{Binding GridName}"
                                                   Width="60"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Normal"/>
                                        <TextBlock Text="{Binding DetectedOrientation}"
                                                   Width="60"
                                                   VerticalAlignment="Center"
                                                   FontWeight="Normal"
                                                   Foreground="Gray"
                                                   FontStyle="Italic"/>
                                        <ComboBox ItemsSource="{Binding AssignableOrientations}"
                                                  SelectedValue="{Binding Orientation, Mode=TwoWay}"
                                                  FontWeight="Normal"
                                                  Width="100"
                                                  SelectionChanged="OtherGridOrientation_Changed"/>
                                    </DockPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Expander>

                <!-- ── INTERSECTION COUNT ─────────────────────── -->
                <TextBlock x:Name="TblIntersectionCount"
                           Grid.Row="5"
                           Text="0 intersections found"
                           FontWeight="Normal"
                           FontStyle="Italic"
                           Foreground="Gray"
                           Margin="0,6,0,0"/>

                <!-- ── RESULTS ────────────────────────────────── -->
                <Expander x:Name="ResultsExpander"
                          Header="Results"
                          Grid.Row="6"
                          Visibility="Collapsed">
                    <Grid Margin="6,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Text="Labels placed:"        Grid.Row="0" Grid.Column="0" FontWeight="Normal"/>
                        <TextBlock x:Name="TblResultPlaced"     Grid.Row="0" Grid.Column="2" FontWeight="Normal" Text="0"/>

                        <TextBlock Text="Labels deleted:"       Grid.Row="1" Grid.Column="0" FontWeight="Normal"/>
                        <TextBlock x:Name="TblResultDeleted"    Grid.Row="1" Grid.Column="2" FontWeight="Normal" Text="0"/>

                        <TextBlock Text="Skipped:"              Grid.Row="2" Grid.Column="0" FontWeight="Normal"/>
                        <TextBlock x:Name="TblResultSkipped"    Grid.Row="2" Grid.Column="2" FontWeight="Normal" Text="0"/>

                        <TextBlock Text="Errors:"               Grid.Row="3" Grid.Column="0" FontWeight="Normal"/>
                        <TextBlock x:Name="TblResultErrors"     Grid.Row="3" Grid.Column="2" FontWeight="Normal" Foreground="Red" Text="0"/>

                        <TextBlock x:Name="TblResultDetails"    Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="3"
                                   FontWeight="Normal" FontStyle="Italic" Foreground="Gray"
                                   TextWrapping="Wrap" Margin="0,4,0,0" Visibility="Collapsed"/>
                    </Grid>
                </Expander>
            </Grid>

        </Grid>

        <!-- ═══ Bottom action bar ═════════════════════════════════ -->
        <StackPanel Grid.Row="1" Margin="0,8,0,0">
            <Grid HorizontalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="160"/>
                    <ColumnDefinition Width="6"/>
                    <ColumnDefinition Width="160"/>
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnPlaceLabels"
                        Grid.Column="0"
                        Content="Place Labels"
                        Height="34"
                        FontWeight="Bold"
                        FontSize="13"
                        Click="BtnPlaceLabels_Click"
                        ToolTip="Place coordinate labels at each grid intersection in the active view."/>
                <Button x:Name="BtnDeleteLabels"
                        Grid.Column="2"
                        Content="Delete Labels"
                        Height="34"
                        FontWeight="Bold"
                        FontSize="13"
                        Click="BtnDeleteLabels_Click"
                        ToolTip="Delete all labels placed by this tool in the active view."/>
                <Button x:Name="BtnClose"
                        Grid.Column="4"
                        Content="Close"
                        Height="34"
                        FontWeight="Bold"
                        FontSize="13"
                        Click="BtnClose_Click"/>
            </Grid>
            <TextBlock x:Name="TblStatus"
                       Text="Ready."
                       Foreground="Gray"
                       FontStyle="Italic"
                       Margin="0,5,0,0"
                       HorizontalAlignment="Center"/>
        </StackPanel>

    </Grid>
</Window>
